Set Shell "zsh"
Set FontSize 15
Set Width 1200
Set Height 820
Set TypingSpeed 20ms

Type "ORC_HOME=/tmp/orc-vhs-phase6 env -u NO_COLOR /tmp/pi-orchestra-phase6/release/pi-orchestra --socket /tmp/orc-vhs-phase6/orcd.sock home"
Enter
Sleep 6s
